generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ADJUSTMENT_REQUESTED
  CANCELLED
}

enum ApprovalScopeType {
  GLOBAL
  SYSTEM
  MODULE
  FEATURE
}

enum AuditResult {
  SUCCESS
  FAILURE
}

enum DocumentFormat {
  DOCX
  PDF
}

enum FunctionalItemScopeType {
  GENERAL
  STATE_SPECIFIC
}

enum VersionStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum VersionedEntityType {
  SYSTEM
  MODULE
  FEATURE
  FUNCTIONAL_ITEM
  DOCUMENT_TEMPLATE
  ADHERENCE_ANALYSIS
}

enum SnapshotType {
  BEFORE
  AFTER
  APPROVED
  PUBLISHED
}

enum ChangeType {
  CREATE
  UPDATE
  REORDER
  REPLACE
  LOGICAL_DELETE
  RESTORE
  IMPORT
  APPROVAL_DECISION
}

enum DocumentDiffMarker {
  NONE
  INSERTED
  UPDATED
  REMOVED
  REPLACED
  MOVED
}

enum ChangeImpactLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Company {
  id               String            @id @default(cuid())
  name             String            @unique
  description      String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  userRoles        CompanyUserRole[]
  systems          System[]
  modules          SystemModule[]
  features         Feature[]
  functionalItems  FunctionalItem[]
  versions         Version[]
  changeSets       ChangeSet[]
  approvalRequests ApprovalRequest[]
}

model User {
  id                     String                  @id @default(cuid())
  name                   String
  email                  String                  @unique
  phone                  String?
  login                  String                  @unique
  passwordHash           String
  status                 UserStatus              @default(ACTIVE)
  canApprove             Boolean                 @default(false)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  roles                  UserRole[]
  companyRoles           CompanyUserRole[]
  approvalScopes         ApprovalScope[]
  createdFunctionalItems FunctionalItem[]        @relation("FunctionalItemCreatedBy")
  updatedFunctionalItems FunctionalItem[]        @relation("FunctionalItemUpdatedBy")
  deletedFunctionalItems FunctionalItem[]        @relation("FunctionalItemDeletedBy")
  createdVersions        Version[]               @relation("VersionCreatedBy")
  approvedVersions       Version[]               @relation("VersionApprovedBy")
  createdChangeSets      ChangeSet[]             @relation("ChangeSetCreatedBy")
  approvalRequests       ApprovalRequest[]       @relation("ApprovalRequestedBy")
  approvalDecisions      ApprovalDecision[]
  auditLogs              AuditLog[]
  documentLogs           DocumentGenerationLog[]
}

model Role {
  id           String            @id @default(cuid())
  code         String            @unique
  name         String
  description  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  users        UserRole[]
  companyUsers CompanyUserRole[]
  permissions  RolePermission[]
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model CompanyUserRole {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  roleId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, companyId])
  @@index([companyId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model ApprovalScope {
  id        String            @id @default(cuid())
  userId    String
  type      ApprovalScopeType
  systemId  String?
  moduleId  String?
  featureId String?
  createdAt DateTime          @default(now())
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  system    System?           @relation(fields: [systemId], references: [id])
  module    SystemModule?     @relation(fields: [moduleId], references: [id])
  feature   Feature?          @relation(fields: [featureId], references: [id])
}

model Nature {
  id              String           @id @default(cuid())
  code            String           @unique
  name            String
  description     String?
  isActive        Boolean          @default(true)
  sortOrder       Int              @default(0)
  functionalItems FunctionalItem[]
}

model ItemStatus {
  id              String           @id @default(cuid())
  code            String           @unique
  name            String
  description     String?
  isActive        Boolean          @default(true)
  sortOrder       Int              @default(0)
  functionalItems FunctionalItem[]
}

model OpinionType {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  description      String?
  requiresApproval Boolean           @default(false)
  isActive         Boolean           @default(true)
  sortOrder        Int               @default(0)
  functionalItems  FunctionalItem[]
  approvals        ApprovalRequest[]
}

model BrazilianState {
  id              String                @id @default(cuid())
  code            String                @unique
  name            String
  region          String?
  isActive        Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  functionalItems FunctionalItemState[]
}

model System {
  id              String           @id @default(cuid())
  companyId       String
  name            String
  slug            String
  description     String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  modules         SystemModule[]
  functionalItems FunctionalItem[]
  approvalScopes  ApprovalScope[]

  @@unique([companyId, slug])
  @@index([companyId])
}

model SystemModule {
  id              String           @id @default(cuid())
  companyId       String
  systemId        String
  name            String
  slug            String
  description     String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  system          System           @relation(fields: [systemId], references: [id], onDelete: Restrict)
  features        Feature[]
  functionalItems FunctionalItem[]
  approvalScopes  ApprovalScope[]

  @@unique([systemId, slug])
  @@index([companyId])
}

model Feature {
  id              String           @id @default(cuid())
  companyId       String
  moduleId        String
  name            String
  slug            String
  description     String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  module          SystemModule     @relation(fields: [moduleId], references: [id], onDelete: Restrict)
  functionalItems FunctionalItem[]
  approvalScopes  ApprovalScope[]

  @@unique([moduleId, slug])
  @@index([companyId])
}

model FunctionalItem {
  id               String                  @id @default(cuid())
  companyId        String
  systemId         String
  moduleId         String
  featureId        String
  hierarchyCode    String
  position         Int
  natureId         String
  statusId         String
  opinionTypeId    String?
  title            String
  description      String
  pocRequired      Boolean                 @default(false)
  scopeType        FunctionalItemScopeType @default(GENERAL)
  currentVersion   String
  observation      String?                 @map("observations")
  isDeleted        Boolean                 @default(false)
  deletedAt        DateTime?
  deletedById      String?
  deletedReason    String?
  createdById      String
  updatedById      String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  company          Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  system           System                  @relation(fields: [systemId], references: [id], onDelete: Restrict)
  module           SystemModule            @relation(fields: [moduleId], references: [id], onDelete: Restrict)
  feature          Feature                 @relation(fields: [featureId], references: [id], onDelete: Restrict)
  nature           Nature                  @relation(fields: [natureId], references: [id], onDelete: Restrict)
  status           ItemStatus              @relation(fields: [statusId], references: [id], onDelete: Restrict)
  opinionType      OpinionType?            @relation(fields: [opinionTypeId], references: [id], onDelete: SetNull)
  createdBy        User                    @relation("FunctionalItemCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy        User?                   @relation("FunctionalItemUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  deletedBy        User?                   @relation("FunctionalItemDeletedBy", fields: [deletedById], references: [id], onDelete: Restrict)
  states           FunctionalItemState[]
  approvalRequests ApprovalRequest[]

  @@index([companyId, systemId, moduleId, featureId])
  @@index([featureId, position])
  @@index([featureId, hierarchyCode])
}

model FunctionalItemState {
  id               String         @id @default(cuid())
  functionalItemId String
  stateId          String
  createdAt        DateTime       @default(now())
  functionalItem   FunctionalItem @relation(fields: [functionalItemId], references: [id], onDelete: Cascade)
  state            BrazilianState @relation(fields: [stateId], references: [id], onDelete: Restrict)

  @@unique([functionalItemId, stateId])
}

model Version {
  id               String              @id @default(cuid())
  companyId        String
  entityType       VersionedEntityType
  entityId         String
  versionCode      String
  status           VersionStatus       @default(DRAFT)
  baseVersionId    String?
  createdById      String
  approvedById     String?
  publishedAt      DateTime?
  approvedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  company          Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  baseVersion      Version?            @relation("VersionBase", fields: [baseVersionId], references: [id], onDelete: SetNull)
  derivedVersions  Version[]           @relation("VersionBase")
  createdBy        User                @relation("VersionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  approvedBy       User?               @relation("VersionApprovedBy", fields: [approvedById], references: [id], onDelete: Restrict)
  snapshots        Snapshot[]
  baseChangeSets   ChangeSet[]         @relation("ChangeSetBaseVersion")
  targetChangeSets ChangeSet[]         @relation("ChangeSetTargetVersion")
  approvalRequests ApprovalRequest[]

  @@unique([entityType, entityId, versionCode])
  @@index([companyId, entityType, entityId])
  @@index([status])
}

model Snapshot {
  id                    String              @id @default(cuid())
  versionId             String
  entityType            VersionedEntityType
  entityId              String
  snapshotType          SnapshotType
  data                  Json
  treeContext           Json?
  hierarchyContext      Json?
  documentRenderContext Json?
  createdAt             DateTime            @default(now())
  version               Version             @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([versionId, snapshotType])
  @@index([entityType, entityId])
}

model ChangeSet {
  id                String              @id @default(cuid())
  companyId         String
  entityType        VersionedEntityType
  entityId          String
  changeType        ChangeType
  baseVersionId     String?
  targetVersionId   String?
  approvalRequestId String?
  reason            String?
  createdById       String
  createdAt         DateTime            @default(now())
  company           Company             @relation(fields: [companyId], references: [id], onDelete: Restrict)
  baseVersion       Version?            @relation("ChangeSetBaseVersion", fields: [baseVersionId], references: [id], onDelete: SetNull)
  targetVersion     Version?            @relation("ChangeSetTargetVersion", fields: [targetVersionId], references: [id], onDelete: SetNull)
  approvalRequest   ApprovalRequest?    @relation(fields: [approvalRequestId], references: [id], onDelete: SetNull)
  createdBy         User                @relation("ChangeSetCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  items             ChangeSetItem[]

  @@index([companyId, entityType, entityId])
  @@index([changeType])
}

model ChangeSetItem {
  id               String              @id @default(cuid())
  changeSetId      String
  entityType       VersionedEntityType
  entityId         String
  fieldPath        String
  previousValue    Json?
  nextValue        Json?
  oldPosition      Int?
  newPosition      Int?
  oldHierarchyCode String?
  newHierarchyCode String?
  documentMarker   DocumentDiffMarker  @default(NONE)
  renderHint       String?
  impactLevel      ChangeImpactLevel   @default(LOW)
  createdAt        DateTime            @default(now())
  changeSet        ChangeSet           @relation(fields: [changeSetId], references: [id], onDelete: Cascade)

  @@index([changeSetId])
  @@index([entityType, entityId])
}

model ApprovalRequest {
  id               String             @id @default(cuid())
  companyId        String
  functionalItemId String
  versionId        String?
  opinionTypeId    String?
  status           ApprovalStatus     @default(PENDING)
  requestedById    String
  requestedAt      DateTime           @default(now())
  resolvedAt       DateTime?
  notes            String?
  company          Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  functionalItem   FunctionalItem     @relation(fields: [functionalItemId], references: [id], onDelete: Cascade)
  version          Version?           @relation(fields: [versionId], references: [id], onDelete: SetNull)
  opinionType      OpinionType?       @relation(fields: [opinionTypeId], references: [id], onDelete: SetNull)
  requestedBy      User               @relation("ApprovalRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict)
  decisions        ApprovalDecision[]
  changeSets       ChangeSet[]

  @@index([companyId, status])
}

model ApprovalDecision {
  id                String          @id @default(cuid())
  approvalRequestId String
  approverId        String
  decision          ApprovalStatus
  comment           String?
  createdAt         DateTime        @default(now())
  approvalRequest   ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  approver          User            @relation(fields: [approverId], references: [id], onDelete: Restrict)
}

model AuditLog {
  id            String      @id @default(cuid())
  userId        String?
  entity        String
  entityId      String?
  action        String
  previousValue Json?
  newValue      Json?
  result        AuditResult @default(SUCCESS)
  ipAddress     String?
  metadata      Json?
  createdAt     DateTime    @default(now())
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model DocumentGenerationLog {
  id        String         @id @default(cuid())
  userId    String
  format    DocumentFormat
  filters   Json?
  fileName  String?
  status    String
  metadata  Json?
  createdAt DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Restrict)
}
